<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:aop="http://www.springframework.org/schema/aop"
       xmlns:context="http://www.springframework.org/schema/context"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd
           http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context.xsd
           http://www.springframework.org/schema/aop http://www.springframework.org/schema/aop/spring-aop.xsd">

    <!-- Bean Definitions (Exercise 1) -->
    <!-- Book Repository -->
    <bean id="bookRepository" class="com.library.repository.BookRepository" />

    <!-- Book Service using Setter Injection (Exercise 2, 5, 7) -->
    <bean id="bookServiceSetter" class="com.library.service.BookService">
        <property name="bookRepository" ref="bookRepository" />
    </bean>

    <!-- Book Service using Constructor Injection (Exercise 7) -->
    <bean id="bookServiceConstructor" class="com.library.service.BookService">
        <constructor-arg ref="bookRepository" />
    </bean>

    <!-- Aspect Bean (Exercise 3, 8) -->
    <bean id="loggingAspect" class="com.library.aspect.LoggingAspect" />

    <!-- Enable AspectJ AutoProxying (Exercise 3, 8) -->
    <aop:aspectj-autoproxy />
</beans>
